DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=your-host.example,your-ip
DJANGO_TIME_ZONE=Asia/Shanghai
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-host.example

DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
DJANGO_SECURE_PROXY_SSL_HEADER=1
DJANGO_SECURE_HSTS_SECONDS=604800
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=0
DJANGO_SECURE_HSTS_PRELOAD=0

POSTGRES_DB=mousexgene
POSTGRES_USER=mousexgene
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

DB_HOST=db
DB_PORT=5432
